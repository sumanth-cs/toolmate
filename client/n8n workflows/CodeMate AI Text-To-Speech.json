      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nif(!staticData.apiKeys){\n staticData.apiKeys = [\n  \"96498d4081mshc6834abd3013b32p19c125jsnf2d31734d722\",\n  \"YOUR_SECOND_TTS_KEY\"\n ];\n staticData.keyIndex = 0;\n}\n\nconst body = $('Webhook').item.json.body || {};\n\nreturn [{\n json:{\n  text: body.input || 'Hello, welcome to CodeMate AI.',\n  voice: body.voice || 'alloy',\n  model: body.model || 'tts-1',\n  instructions: body.instructions || 'Speak clearly.',\n  apiKey: staticData.apiKeys[staticData.keyIndex]\n }\n}];"
      },
