        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $json.model }}\",\n  \"input\": \"{{ $json.text }}\",\n  \"instructions\": \"{{ $json.instructions }}\",\n  \"voice\": \"{{ $json.voice }}\"\n}",
