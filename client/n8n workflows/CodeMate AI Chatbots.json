    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nif(!staticData.apiKeys){\n staticData.apiKeys = [\n  \"6705f6c2aemsh5ebe51663051d47p11e343jsne4aeaa2a0469\",\n  \"fd4b480f62msh914725249be31b0p15b789jsn9e23a9bf2dbb\",\n  \"YOUR_RAPID_API_KEY_2\"\n ];\n staticData.keyIndex = 0;\n}\n\nconst body = $('Webhook').item.json.body || {};\n\n// We accept a full messages array, OR we wrap a simple prompt into the required array format\nconst defaultPrompt = body.prompt || 'Write a short story about four cats.';\nconst messages = body.messages || [{ \"role\": \"user\", \"content\": defaultPrompt }];\n\n// Default to GPT-4o if the frontend doesn't specify\nconst model = body.model || 'openai/gpt-4o';\n\nreturn [{\n json:{\n  model: model,\n  messages: messages,\n  temperature: body.temperature || 0.7,\n  apiKey: staticData.apiKeys[staticData.keyIndex]\n }\n}];"
      },
      "id": "f7d73fd8-c9c8-458a-ba9d-030e3520f276",
